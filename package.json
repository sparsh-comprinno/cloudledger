{
  "name": "cloudledger",
  "private": true,
  "version": "1.0.0",
  "description": "AWS Resource Inventory - macOS desktop application for comprehensive cloud resource discovery",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "electron ."
